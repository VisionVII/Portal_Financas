# Auth Service — Variáveis de Ambiente
# Copie para .env e preencha

# Banco de dados (Docker local)
DATABASE_URL="postgresql://portal:portal_dev_2026@localhost:5432/portal_financas?schema=auth"

# Redis (sessões e cache)
REDIS_URL="redis://localhost:6379"

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=gere_um_secret_forte_aqui
JWT_REFRESH_SECRET=gere_outro_secret_forte_aqui

# Expiração dos tokens
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Porta do serviço
PORT=3001

# OAuth (opcional por enquanto)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
