# =============================================================
# Portal Finanças — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# =============================================================

# --- CoinGecko Demo API ---
# Cadastro: https://www.coingecko.com/api/documentation
# Clique em "Get Demo API Key" (gratuito)
COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- brapi.dev (Ações BR — B3) ---
# Cadastro: https://brapi.dev
# Clique em "Obter Token" (gratuito)
BRAPI_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Twelve Data (Ações US + Forex) ---
# Cadastro: https://twelvedata.com/pricing → plano Free
TWELVE_DATA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Alpha Vantage (fallback para ações US) ---
# Cadastro: https://www.alphavantage.co/support/#api-key (gratuito)
ALPHA_VANTAGE_API_KEY=xxxxxxxxxxxxxxxx

# --- Binance (WebSocket — sem chave, dados públicos) ---
# Nenhuma chave necessária para streams públicos
NEXT_PUBLIC_BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
